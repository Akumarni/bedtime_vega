{
  "rules": {
    "families": {
      "$familyId": {
        ".read": true,
        ".write": true,
        "info": {
          ".validate": "newData.hasChildren(['name', 'pin'])"
        },
        "children": {
          "$childId": {
            ".validate": "newData.hasChild('name') && newData.hasChild('avatar') && newData.hasChild('order')",
            "checklistItems": {
              "$itemId": {
                ".validate": "newData.hasChildren(['title', 'icon', 'order'])"
              }
            },
            "rewards": {
              "$rewardId": {
                ".validate": "newData.hasChildren(['title', 'icon'])"
              }
            },
            "timerMinutes": {
              ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 60"
            }
          }
        }
      }
    },
    "tonight": {
      "$familyId": {
        ".read": true,
        ".write": true,
        "$dateKey": {
          "$childId": {
            "items": {
              "$itemId": {
                ".validate": "newData.isBoolean()"
              }
            },
            "allComplete": {
              ".validate": "newData.isBoolean()"
            },
            "completedAt": {
              ".validate": "newData.isNumber()"
            },
            "timerStartedAt": {
              ".validate": "newData.isNumber()"
            },
            "rewardWon": {
              ".validate": "newData.isString()"
            },
            "rewardIcon": {
              ".validate": "newData.isString()"
            }
          }
        }
      }
    },
    "history": {
      "$familyId": {
        ".read": true,
        ".write": true,
        "$childId": {
          "$entryId": {
            ".validate": "newData.hasChildren(['date', 'rewardTitle', 'rewardIcon', 'timestamp'])"
          }
        }
      }
    },
    "devices": {
      "$deviceId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChild('familyId')"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
